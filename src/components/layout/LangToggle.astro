---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLangFromUrl } from '../../i18n/utils';
import Icon from '../base/Icon.astro';

interface Props {
  /** Override do href de destino. Use quando o caminho difere por idioma
   *  (ex.: posts sem tradução). Sem isso, o destino é computado da URL atual. */
  to?: string;
}
const { to } = Astro.props;

const current = getLangFromUrl(Astro.url);
const other = current === 'pt' ? 'en' : 'pt';

// caminho lógico sem base e sem prefixo de locale
const base = import.meta.env.BASE_URL;
const stripped = Astro.url.pathname.startsWith(base)
  ? Astro.url.pathname.slice(base.length)
  : Astro.url.pathname.replace(/^\//, '');
const parts = stripped.split('/').filter(Boolean);
if (parts[0] === 'pt' || parts[0] === 'en') parts.shift();
const logical = parts.join('/');

const href = to ?? getRelativeLocaleUrl(other, logical);
const label = other.toUpperCase();
---

<a class="lang" href={href} aria-label={`${other === 'en' ? 'Switch to English' : 'Mudar para Português'}`}>
  <Icon name="globe" size={16} />
  <span>{label}</span>
</a>

<style>
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    padding: 0.45em 0.7em;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    transition:
      color var(--transition),
      border-color var(--transition);
  }
  .lang:hover {
    color: var(--text-strong);
    border-color: var(--accent-cyan);
  }
</style>
