---
import { useTranslations } from '../../i18n/utils';
import type { Locale } from '../../config/site';
import { profile } from '../../data/profile';
import { certifications } from '../../data/certifications';
import { linkedInProjects } from '../../data/linkedin-projects';
import { talks } from '../../data/talks';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const stats = [
  { value: `${profile.experienceYears}+`, label: t('stats.years') },
  { value: `${certifications.length}`, label: t('stats.certs') },
  { value: `${linkedInProjects.length}`, label: t('stats.projects') },
  { value: `${talks.length}`, label: t('stats.talks') },
];
---

<section class="stats-section">
  <div class="container">
    <div class="grid" data-reveal>
      {
        stats.map((s) => (
          <div class="stat">
            <span class="value gradient-text">{s.value}</span>
            <span class="label">{s.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats-section {
    padding-block: var(--space-lg);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-md);
    border-block: 1px solid var(--border);
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.3rem;
  }
  .value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1;
  }
  .label {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  @media (max-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg) var(--space-md);
    }
  }
</style>
