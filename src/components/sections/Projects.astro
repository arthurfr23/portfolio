---
import { useTranslations } from '../../i18n/utils';
import type { Locale } from '../../config/site';
import { channels } from '../../data/channels';
import { getProjects } from '../../lib/github';
import SectionHeading from '../base/SectionHeading.astro';
import RepoCard from '../cards/RepoCard.astro';
import EmptyState from '../base/EmptyState.astro';
import Icon from '../base/Icon.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = await getProjects();
const ghUrl = `https://github.com/${channels.github.username}`;
---

<section id="projects" class="section">
  <div class="container">
    <SectionHeading
      eyebrow={t('projects.eyebrow')}
      title={t('projects.title')}
      subtitle={t('projects.subtitle')}
    />
    {
      projects.length > 0 ? (
        <>
          <div class="grid">
            {projects.map((p) => (
              <RepoCard project={p} lang={lang} />
            ))}
          </div>
          <div class="more">
            <a href={ghUrl} target="_blank" rel="noopener noreferrer">
              {t('projects.viewAll')}
              <Icon name="arrow-up-right" size={16} />
            </a>
          </div>
        </>
      ) : (
        <EmptyState
          icon="github"
          message={t('projects.empty')}
          ctaLabel={t('projects.viewAll')}
          ctaHref={ghUrl}
        />
      )
    }
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }
  .more {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }
  .more a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent-cyan);
    font-weight: 500;
  }
  .more a:hover {
    color: white;
  }
</style>
