---
import { useTranslations } from '../../i18n/utils';
import type { Locale } from '../../config/site';
import { profile } from '../../data/profile';
import { channels } from '../../data/channels';
import SectionHeading from '../base/SectionHeading.astro';
import Button from '../base/Button.astro';
import Icon from '../base/Icon.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const socials = [
  { name: 'github', href: `https://github.com/${channels.github.username}`, label: 'GitHub' },
  { name: 'linkedin', href: channels.linkedin.url, label: 'LinkedIn' },
  { name: 'youtube', href: channels.youtube.url, label: 'YouTube' },
  { name: 'medium', href: channels.medium.url, label: 'Medium' },
];
---

<section id="contact" class="section">
  <div class="container">
    <div class="panel glass">
      <SectionHeading
        eyebrow={t('contact.eyebrow')}
        title={t('contact.title')}
        subtitle={t('contact.subtitle')}
        align="center"
      />
      <div class="cta">
        <Button href={`mailto:${profile.email}`} variant="primary">
          <Icon name="mail" size={18} />
          {t('contact.email')}
        </Button>
      </div>
      <div class="socials">
        {
          socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
              <Icon name={s.name} size={22} />
              <span>{s.label}</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .panel {
    padding: clamp(2rem, 6vw, 4.5rem);
    text-align: center;
  }
  .cta {
    display: flex;
    justify-content: center;
    margin-top: calc(-1 * var(--space-sm));
  }
  .socials {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: var(--space-lg);
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    padding: 0.55em 1.1em;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    transition:
      color var(--transition),
      border-color var(--transition);
  }
  .socials a:hover {
    color: var(--text-strong);
    border-color: var(--accent-cyan);
  }
</style>
