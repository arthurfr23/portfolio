---
import { useTranslations } from '../../i18n/utils';
import type { Locale } from '../../config/site';
import { channels } from '../../data/channels';
import { getProjects, getGithubSummary } from '../../lib/github';
import SectionHeading from '../base/SectionHeading.astro';
import RepoCard from '../cards/RepoCard.astro';
import EmptyState from '../base/EmptyState.astro';
import Icon from '../base/Icon.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const repos = await getProjects();
const summary = await getGithubSummary();
const ghUrl = `https://github.com/${channels.github.username}`;
---

<section id="repos" class="section">
  <div class="container">
    <SectionHeading
      eyebrow={t('repos.eyebrow')}
      title={t('repos.title')}
      subtitle={t('repos.subtitle')}
    />
    {
      summary.publicRepos > 0 && (
        <div class="snapshot mono" data-reveal>
          <span>
            <strong>{summary.publicRepos}</strong> repos
          </span>
          {summary.totalStars > 0 && (
            <span>
              <Icon name="star" size={14} /> <strong>{summary.totalStars}</strong>
            </span>
          )}
          {summary.topLanguages.length > 0 && <span>{summary.topLanguages.join(' · ')}</span>}
        </div>
      )
    }
    {
      repos.length > 0 ? (
        <>
          <div class="grid">
            {repos.map((r) => (
              <RepoCard project={r} lang={lang} />
            ))}
          </div>
          <div class="more">
            <a href={ghUrl} target="_blank" rel="noopener noreferrer">
              {t('repos.viewAll')}
              <Icon name="arrow-up-right" size={16} />
            </a>
          </div>
        </>
      ) : (
        <EmptyState
          icon="github"
          message={t('repos.empty')}
          ctaLabel={t('repos.viewAll')}
          ctaHref={ghUrl}
        />
      )
    }
  </div>
</section>

<style>
  .snapshot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    margin-top: calc(-1 * var(--space-md));
    margin-bottom: var(--space-lg);
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .snapshot span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .snapshot strong {
    color: var(--accent-cyan);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }
  .more {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }
  .more a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent-cyan);
    font-weight: 500;
  }
  .more a:hover {
    color: white;
  }
</style>
