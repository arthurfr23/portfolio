---
import type { VideoInfo } from '../../lib/youtube';
import type { Locale } from '../../config/site';
import { formatDateShort } from '../../i18n/utils';
import Card from '../base/Card.astro';
import Icon from '../base/Icon.astro';

interface Props {
  video: VideoInfo;
  lang: Locale;
}
const { video, lang } = Astro.props;
---

<Card href={video.url} external flush class="video">
  <div class="thumb">
    <img
      src={video.thumbnail}
      alt={video.title}
      width="320"
      height="180"
      loading="lazy"
      decoding="async"
    />
    <span class="play"><Icon name="play" size={22} /></span>
  </div>
  <div class="meta">
    <h3>{video.title}</h3>
    <span class="date">{formatDateShort(video.published, lang)}</span>
  </div>
</Card>

<style>
  .thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--bg-elevated);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: color-mix(in oklab, #ff0000 85%, black);
    color: white;
    opacity: 0.9;
    transition: transform var(--transition);
  }
  .video:hover .play {
    transform: scale(1.12);
  }
  .meta {
    padding: var(--space-md);
  }
  h3 {
    font-size: 1.05rem;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .date {
    display: block;
    margin-top: 0.5rem;
    color: var(--text-faint);
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }
</style>
