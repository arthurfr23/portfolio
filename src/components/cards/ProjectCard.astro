---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { LinkedInProject } from '../../data/types';
import type { Locale } from '../../config/site';
import { formatMonthYear } from '../../i18n/utils';
import Card from '../base/Card.astro';
import Badge from '../base/Badge.astro';
import Icon from '../base/Icon.astro';

interface Props {
  project: LinkedInProject;
  lang: Locale;
  presentLabel: string;
  caseStudyLabel: string;
}
const { project, lang, presentLabel, caseStudyLabel } = Astro.props;

const start = formatMonthYear(project.startDate, lang);
const end = project.endDate ? formatMonthYear(project.endDate, lang) : presentLabel;
const period = `${start} — ${end}`;

const paragraphs = project.description[lang].split('\n\n').filter(Boolean);

const caseUrl = project.caseSlug
  ? getRelativeLocaleUrl(lang, `projects/${project.caseSlug}`)
  : undefined;

// Card clicável só quando NÃO há case study (para não aninhar links).
const cardHref = caseUrl ? undefined : project.url;
const cardExternal = Boolean(cardHref);
---

<Card href={cardHref} external={cardExternal} class="project-card" hover>
  <div class="head">
    <div class="meta">
      <span class="period mono">{period}</span>
      {project.company && <span class="company">{project.company}</span>}
    </div>
    {cardHref && <Icon name="arrow-up-right" size={16} class="ext-icon" />}
  </div>

  <h3>{project.title[lang]}</h3>

  <div class="desc">
    {paragraphs.map((p) => <p>{p}</p>)}
  </div>

  {
    project.tags.length > 0 && (
      <div class="tags">
        {project.tags.map((tag) => (
          <Badge variant="outline">{tag}</Badge>
        ))}
      </div>
    )
  }

  {
    caseUrl && (
      <div class="actions">
        <a class="case-link" href={caseUrl}>
          {caseStudyLabel}
          <Icon name="arrow-right" size={15} />
        </a>
        {project.url && (
          <a class="ext-link" href={project.url} target="_blank" rel="noopener noreferrer" aria-label="Link">
            <Icon name="arrow-up-right" size={15} />
          </a>
        )}
      </div>
    )
  }
</Card>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: var(--space-sm);
  }
  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .period {
    font-size: 0.8rem;
    color: var(--accent-cyan);
  }
  .company {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .ext-icon {
    color: var(--text-faint);
    flex-shrink: 0;
    margin-top: 2px;
    transition: color var(--transition);
  }
  .project-card:hover .ext-icon {
    color: var(--accent-cyan);
  }
  h3 {
    font-size: 1.15rem;
    margin-bottom: var(--space-xs);
  }
  .desc {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.4rem;
  }
  .desc p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: var(--space-md);
  }
  .actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border);
  }
  .case-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent-cyan);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .case-link:hover {
    color: white;
  }
  .ext-link {
    color: var(--text-faint);
  }
  .ext-link:hover {
    color: var(--text-strong);
  }
</style>
