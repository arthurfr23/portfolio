---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../config/site';
import { formatDateShort, withBase } from '../../i18n/utils';
import Card from '../base/Card.astro';
import Badge from '../base/Badge.astro';
import Icon from '../base/Icon.astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  cover?: string;
  lang: Locale;
}
const { slug, title, description, date, tags, cover, lang } = Astro.props;
const href = getRelativeLocaleUrl(lang, `blog/${slug}`);
---

<Card href={href} flush class="post-card" hover>
  <div class="cover">
    {
      cover ? (
        <img src={withBase(cover)} alt={title} width="320" height="160" loading="lazy" decoding="async" />
      ) : (
        <div class="cover-fallback">
          <Icon name="code" size={32} />
        </div>
      )
    }
  </div>
  <div class="body">
    <span class="date mono">{formatDateShort(date.toISOString(), lang)}</span>
    <h3>{title}</h3>
    <p class="desc">{description}</p>
    {
      tags.length > 0 && (
        <div class="tags">
          {tags.slice(0, 3).map((tag) => (
            <Badge variant="outline">{tag}</Badge>
          ))}
        </div>
      )
    }
  </div>
</Card>

<style>
  .cover {
    aspect-ratio: 2 / 1;
    background: var(--bg-elevated);
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cover-fallback {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: var(--text-faint);
    background:
      radial-gradient(60% 80% at 30% 20%, rgba(59, 130, 246, 0.18), transparent),
      radial-gradient(60% 80% at 80% 90%, rgba(16, 185, 129, 0.14), transparent),
      var(--bg-elevated);
  }
  .body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
  }
  .date {
    color: var(--text-faint);
    font-size: 0.8rem;
  }
  h3 {
    font-size: 1.15rem;
    line-height: 1.35;
    margin-top: 0.4rem;
  }
  .desc {
    margin-top: 0.5rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: var(--space-md);
  }
</style>
