---
import type { Locale } from '../config/site';
import Header from './layout/Header.astro';
import Footer from './layout/Footer.astro';
import Hero from './sections/Hero.astro';
import Stats from './sections/Stats.astro';
import About from './sections/About.astro';
import Skills from './sections/Skills.astro';
import Experience from './sections/Experience.astro';
import LinkedInProjects from './sections/LinkedInProjects.astro';
import Repos from './sections/Repos.astro';
import Videos from './sections/Videos.astro';
import Articles from './sections/Articles.astro';
import Talks from './sections/Talks.astro';
import Certifications from './sections/Certifications.astro';
import Newsletter from './sections/Newsletter.astro';
import Contact from './sections/Contact.astro';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
---

<Header lang={lang} />
<main>
  <Hero lang={lang} />
  <Stats lang={lang} />
  <About lang={lang} />
  <Skills lang={lang} />
  <Experience lang={lang} />
  <LinkedInProjects lang={lang} />
  <Repos lang={lang} />
  <Videos lang={lang} />
  <Articles lang={lang} />
  <Talks lang={lang} />
  <Certifications lang={lang} />
  <Newsletter lang={lang} />
  <Contact lang={lang} />
</main>
<Footer lang={lang} />
