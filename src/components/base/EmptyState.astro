---
import Icon from './Icon.astro';

interface Props {
  message: string;
  ctaLabel?: string;
  ctaHref?: string;
  icon?: string;
}
const { message, ctaLabel, ctaHref, icon = 'sparkles' } = Astro.props;
---

<div class="empty glass">
  <Icon name={icon} size={28} />
  <p>{message}</p>
  {
    ctaHref && ctaLabel && (
      <a href={ctaHref} target="_blank" rel="noopener noreferrer">
        {ctaLabel}
        <Icon name="arrow-up-right" size={15} />
      </a>
    )
  }
</div>

<style>
  .empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: var(--space-xl) var(--space-md);
    color: var(--text-muted);
  }
  .empty :global(svg) {
    color: var(--accent-cyan);
  }
  a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--accent-cyan);
    font-weight: 500;
    font-size: 0.9rem;
  }
  a:hover {
    color: white;
  }
</style>
